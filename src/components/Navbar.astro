---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "首页" },
  { href: "/about", label: "关于我" },
  { href: "/knowledge", label: "知识库" },
  { href: "/projects", label: "个人项目" },
  { href: "/open-source", label: "开源贡献" }
];

const homeAnchors = [
  { id: "timeline", label: "时间轴" },
  { id: "tech-stack", label: "技术栈" },
  { id: "contact", label: "联系我" }
];

const isActive = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand">
      Oguri-Zy
      <span class="brand-dot"></span>
    </a>

    <div class="nav-links">
      {
        links.map((link) => (
          <a href={link.href} class={isActive(link.href) ? "is-active" : undefined}>
            {link.label}
          </a>
        ))
      }
      {
        homeAnchors.map((anchor) => (
          <a href={pathname === "/" ? `#${anchor.id}` : `/#${anchor.id}`}>
            {anchor.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>
