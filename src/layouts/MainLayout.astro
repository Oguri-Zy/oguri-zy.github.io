---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Oguri-Zy | 作品集",
  description = "机器人、机电工程、嵌入式、视觉与智能装备方向的个人网站"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>